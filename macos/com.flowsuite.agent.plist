<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.flowsuite.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON3__</string>
        <string>__APPDIR__/flowsuite.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__APPDIR__</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>
    <key>StandardOutPath</key>
    <string>__APPDIR__/flowsuite.log</string>
    <key>StandardErrorPath</key>
    <string>__APPDIR__/flowsuite.err.log</string>
</dict>
</plist>
